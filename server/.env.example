PORT=3001
# ID de la Google Sheet (la parte entre /d/ y /edit en la URL)
SHEET_ID=1lf3EK7vo3lUnx8uOMZvSnooshiZvboIjcurPasxMEl8
# gid de la pestaña a leer cuando SHEET_ALL_TABS=false (0 = primera pestaña)
SHEET_GID=0
# true (por defecto) = consolida TODAS las pestañas; false = solo SHEET_GID
SHEET_ALL_TABS=true
# Segundos que se cachea la respuesta de Google
CACHE_SECONDS=15

# ─── Imágenes de anuncios (Meta Marketing API) ───
# Token con permiso ads_read. Vacío = desactivado.
META_ACCESS_TOKEN=
META_API_VERSION=v21.0
META_CACHE_MINUTES=60
# Minutos de caché para insights (gasto/rendimiento)
META_INSIGHTS_CACHE_MINUTES=15
